                <field name="id" optional="show"/>
                <field name="x_name"/>
                <field name="x_source_record_id" optional="show"/>
                <field name="x_sequence"/>
                <field name="x_active"/>
            </list>
        </field>
    </record>

    <record id="view_preferred_role_type_form" model="ir.ui.view">
        <field name="name">x_hr.preferred_role_type.form</field>
        <field name="model">x_hr.preferred_role_type</field>
        <field name="arch" type="xml">
            <form string="Preferred Role Type">
                <sheet>
                    <group>
                        <field name="id" readonly="1"/>
                        <field name="x_name"/>
                        <field name="x_source_record_id"/>
                        <field name="x_sequence"/>
                        <field name="x_active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_language_list" model="ir.ui.view">
        <field name="name">x_hr.language.list</field>
        <field name="model">x_hr.language</field>
        <field name="arch" type="xml">
            <list string="Languages">
                <field name="id" optional="show"/>
                <field name="x_name"/>
                <field name="x_name_ar"/>
                <field name="x_name_en"/>
                <field name="x_source_code" optional="show"/>
                <field name="x_source_record_id" optional="show"/>
                <field name="x_sequence" optional="show"/>
                <field name="x_active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_hr_language_form" model="ir.ui.view">
        <field name="name">x_hr.language.form</field>
        <field name="model">x_hr.language</field>
        <field name="arch" type="xml">
            <form string="Language">
                <sheet>
                    <group>
                        <field name="id" readonly="1"/>
                        <field name="x_name"/>
                        <field name="x_name_ar"/>
                        <field name="x_name_en"/>
                    </group>
                    <group>
                        <field name="x_source_code"/>
                        <field name="x_source_record_id"/>
                        <field name="x_sequence"/>
                        <field name="x_active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

