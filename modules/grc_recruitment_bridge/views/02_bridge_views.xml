<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_job_bridge_list" model="ir.ui.view">
        <field name="name">hr.job.recruitment_governance.list</field>
        <field name="model">hr.job</field>
        <field name="arch" type="xml">
            <list string="Baseline Vacancies">
                <field name="name"/>
                <field name="x_grc_functional_area_id"/>
                <field name="x_grc_function_id"/>
                <field name="x_grc_role_template_id"/>
                <field name="x_grc_interview_template_id"/>
                <field name="x_grc_document_checklist_template_id"/>
                <field name="x_grc_declaration_pack_id"/>
                <field name="x_grc_signature_profile_id"/>
            </list>
        </field>
    </record>
    <record id="view_hr_job_bridge_search" model="ir.ui.view">
        <field name="name">hr.job.recruitment_governance.search</field>
        <field name="model">hr.job</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="x_grc_functional_area_id"/>
                <field name="x_grc_function_id"/>
                <field name="x_grc_role_template_id"/>
                <field name="x_grc_interview_template_id"/>
                <field name="x_grc_document_checklist_template_id"/>
                <field name="x_grc_declaration_pack_id"/>
                <field name="x_grc_signature_profile_id"/>
            </search>
        </field>
    </record>
    <record id="view_hr_job_bridge_form" model="ir.ui.view">
        <field name="name">hr.job.recruitment_governance.form</field>
        <field name="model">hr.job</field>
        <field name="arch" type="xml">
            <form string="Baseline Vacancy">
                <header>
                    <button name="%(grc_recruitment_bridge.action_sync_hr_job_recruitment_baseline)d"
                            type="action"
                            string="Sync Baseline"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="x_grc_role_template_id"/>
                            <field name="x_grc_interview_template_id"/>
                            <field name="x_grc_document_checklist_template_id"/>
                            <field name="x_grc_onboarding_pack_id"/>
                            <field name="x_grc_declaration_pack_id"/>
                            <field name="x_grc_signature_profile_id"/>
                            <field name="x_tor_pdf_attachment_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Baseline Vacancy">
                            <group>
                                <field name="x_grc_functional_area_id"/>
                                <field name="x_grc_function_id"/>
                            </group>
                        </page>
                        <page string="Documents">
                            <group>
                                <field name="x_tor_pdf_attachment_id"/>
                            </group>
                        </page>
                        <page string="Template Families">
                            <group>
                                <field name="x_grc_role_template_id"/>
                                <field name="x_grc_interview_template_id"/>
                                <field name="x_grc_document_checklist_template_id"/>
                                <field name="x_grc_onboarding_pack_id"/>
                                <field name="x_grc_declaration_pack_id"/>
                                <field name="x_grc_signature_profile_id"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_applicant_runtime_extension" model="ir.ui.view">
        <field name="name">hr.applicant.recruitment_runtime.form</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="%(grc_recruitment_bridge.action_prepare_applicant_recruitment_runtime)d"
                            type="action"
                            string="Prepare Recruitment Runtime"
                            class="btn-primary"/>
                </header>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Baseline Vacancy">
                    <group>
                        <group>
                            <field name="job_id"/>
                            <field name="x_interview_evaluation_id"/>
                            <field name="x_document_checklist_id"/>
                        </group>
                        <group>
                            <field name="x_signature_profile_id"/>
                            <field name="x_pdf_attachment_id"/>
                            <field name="x_signed_pdf_attachment_id"/>
                        </group>
                    </group>
                </page>
                <page string="Negotiated Role">
                    <group>
                        <field name="x_role_composition_id"/>
                    </group>
                    <field name="x_role_composition_ids" context="{'default_x_job_id': job_id}" mode="tree,form">
                        <tree editable="bottom">
                            <field name="x_code"/>
                            <field name="x_name"/>
                            <field name="x_job_id"/>
                            <field name="x_role_template_id"/>
                            <field name="x_included_line_count"/>
                            <field name="x_state"/>
                        </tree>
                    </field>
                </page>
                <page string="Evaluations">
                    <field name="x_interview_evaluation_ids" context="{'default_x_job_id': job_id}" mode="tree,form">
                        <tree editable="bottom">
                            <field name="x_code"/>
                            <field name="x_name"/>
                            <field name="x_job_id"/>
                            <field name="x_template_id"/>
                            <field name="x_interviewer_user_id"/>
                            <field name="x_total_score"/>
                            <field name="x_completion_ratio"/>
                            <field name="x_state"/>
                        </tree>
                    </field>
                </page>
                <page string="Documents &amp; Checklists">
                    <group>
                        <field name="x_document_checklist_id"/>
                        <field name="x_document_checklist_ids" context="{'default_x_job_id': job_id}" mode="tree,form">
                            <tree editable="bottom">
                                <field name="x_code"/>
                                <field name="x_name"/>
                                <field name="x_job_id"/>
                                <field name="x_template_id"/>
                                <field name="x_completed_line_count"/>
                                <field name="x_completion_ratio"/>
                                <field name="x_state"/>
                            </tree>
                        </field>
                        <field name="x_document_submission_ids" context="{'default_x_job_id': job_id}" mode="tree,form">
                            <tree editable="bottom">
                                <field name="x_code"/>
                                <field name="x_name"/>
                                <field name="x_checklist_line_id"/>
                                <field name="x_document_type_id"/>
                                <field name="x_external_source"/>
                                <field name="x_is_received"/>
                                <field name="x_state"/>
                            </tree>
                        </field>
                    </group>
                </page>
                <page string="Declarations">
                    <group>
                        <field name="x_declaration_envelope_id"/>
                    </group>
                    <field name="x_declaration_envelope_ids" context="{'default_x_job_id': job_id}" mode="tree,form">
                        <tree editable="bottom">
                            <field name="x_code"/>
                            <field name="x_name"/>
                            <field name="x_job_id"/>
                            <field name="x_declaration_pack_id"/>
                            <field name="x_signed_line_count"/>
                            <field name="x_completion_ratio"/>
                            <field name="x_state"/>
                        </tree>
                    </field>
                </page>
                <page string="Signatures">
                    <group>
                        <group>
                            <field name="x_signature_profile_id"/>
                        </group>
                        <group>
                            <field name="x_pdf_attachment_id"/>
                            <field name="x_signed_pdf_attachment_id"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
