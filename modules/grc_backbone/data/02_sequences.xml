<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="seq_grc_compliance_check" model="ir.sequence">
    <field name="name">GRC Compliance Check</field>
    <field name="code">x_grc.compliance_check</field>
    <field name="prefix">CHK-%(year)s-</field>
    <field name="padding">4</field>
    <field name="company_id" eval="False"/>
</record>

<record id="seq_grc_incident" model="ir.sequence">
    <field name="name">GRC Incident</field>
    <field name="code">x_grc.incident</field>
    <field name="prefix">INC-%(year)s-</field>
    <field name="padding">4</field>
    <field name="company_id" eval="False"/>
</record>

<record id="seq_grc_tender" model="ir.sequence">
    <field name="name">GRC Tender</field>
    <field name="code">x_grc.tender</field>
    <field name="prefix">TND-%(year)s-</field>
    <field name="padding">4</field>
    <field name="company_id" eval="False"/>
</record>
</odoo>
