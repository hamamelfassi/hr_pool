<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="model_x_hr_pool_conversion_request" model="ir.model">
        <field name="name">HR Pool Conversion Request</field>
        <field name="model">x_hr.pool_conversion_request</field>
        <field name="state">manual</field>
        <field name="is_mail_thread" eval="True"/>
        <field name="is_mail_activity" eval="True"/>
    </record>

    <record id="field_conversion_request_x_name" model="ir.model.fields">
        <field name="model_id" ref="hr_pool.model_x_hr_pool_conversion_request"/>
        <field name="name">x_name</field>
        <field name="field_description">Request Reference</field>
        <field name="ttype">char</field>
    </record>

    <record id="field_conversion_request_x_pool_id" model="ir.model.fields">
        <field name="model_id" ref="hr_pool.model_x_hr_pool_conversion_request"/>
        <field name="name">x_pool_id</field>
        <field name="field_description">HR Pool</field>
        <field name="ttype">many2one</field>
        <field name="relation">x_hr.pool</field>
        <field name="required" eval="True"/>
        <field name="on_delete">cascade</field>
    </record>

    <record id="field_conversion_request_x_job_id" model="ir.model.fields">
        <field name="model_id" ref="hr_pool.model_x_hr_pool_conversion_request"/>
        <field name="name">x_job_id</field>
        <field name="field_description">Job Position</field>
        <field name="ttype">many2one</field>
        <field name="relation">hr.job</field>
        <field name="required" eval="True"/>
        <field name="on_delete">restrict</field>
    </record>

    <record id="field_conversion_request_x_state" model="ir.model.fields">
        <field name="model_id" ref="hr_pool.model_x_hr_pool_conversion_request"/>
        <field name="name">x_state</field>
        <field name="field_description">Stage</field>
        <field name="ttype">selection</field>
        <field name="required" eval="True"/>
    </record>

    <record id="field_conversion_request_x_notes" model="ir.model.fields">
        <field name="model_id" ref="hr_pool.model_x_hr_pool_conversion_request"/>
        <field name="name">x_notes</field>
        <field name="field_description">Notes</field>
        <field name="ttype">text</field>
    </record>

    <record id="field_conversion_request_x_requested_by" model="ir.model.fields">
        <field name="model_id" ref="hr_pool.model_x_hr_pool_conversion_request"/>
        <field name="name">x_requested_by</field>
        <field name="field_description">Requested By</field>
        <field name="ttype">many2one</field>
        <field name="relation">res.users</field>
        <field name="on_delete">set null</field>
    </record>

    <record id="field_conversion_request_x_decided_by" model="ir.model.fields">
        <field name="model_id" ref="hr_pool.model_x_hr_pool_conversion_request"/>
        <field name="name">x_decided_by</field>
        <field name="field_description">Decided By</field>
        <field name="ttype">many2one</field>
        <field name="relation">res.users</field>
        <field name="on_delete">set null</field>
    </record>

    <record id="field_conversion_request_x_applicant_id" model="ir.model.fields">
        <field name="model_id" ref="hr_pool.model_x_hr_pool_conversion_request"/>
        <field name="name">x_applicant_id</field>
        <field name="field_description">Recruitment Applicant</field>
        <field name="ttype">many2one</field>
        <field name="relation">hr.applicant</field>
        <field name="on_delete">set null</field>
    </record>

    <record id="field_hr_pool_x_conversion_request_ids" model="ir.model.fields">
        <field name="model_id" ref="hr_pool.model_x_hr_pool"/>
        <field name="name">x_conversion_request_ids</field>
        <field name="field_description">Conversion Requests</field>
        <field name="ttype">one2many</field>
        <field name="relation">x_hr.pool_conversion_request</field>
        <field name="relation_field">x_pool_id</field>
    </record>
</odoo>
