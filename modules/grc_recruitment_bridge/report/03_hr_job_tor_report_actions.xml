<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_hr_job_tor" model="ir.actions.report">
        <field name="name">Baseline Job Description / TOR</field>
        <field name="model">hr.job</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">grc_recruitment_bridge.report_hr_job_tor_document</field>
        <field name="report_file">grc_recruitment_bridge.report_hr_job_tor_document</field>
        <field name="paperformat_id" ref="grc_recruitment_bridge.paperformat_hr_recruitment_native"/>
        <field name="binding_model_id" search="[('model','=','hr.job')]"/>
        <field name="binding_view_types">form</field>
        <field name="attachment_use" eval="True"/>
        <field name="attachment">'%s - TOR.pdf' % (object.name or 'HR Job')</field>
    </record>
</odoo>
