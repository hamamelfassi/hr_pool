<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Runtime inverse fields must load before the parent one2many fields -->
    <record id="field_hr_interview_evaluation_line_x_evaluation_id" model="ir.model.fields">
        <field name="model_id" ref="grc_recruitment_bridge.model_hr_interview_evaluation_line"/>
        <field name="name">x_evaluation_id</field>
        <field name="field_description">Interview Evaluation</field>
        <field name="ttype">many2one</field>
        <field name="relation">x_hr.recruitment_interview_evaluation</field>
        <field name="on_delete">restrict</field>
    </record>

    <record id="field_hr_document_checklist_line_x_checklist_id" model="ir.model.fields">
        <field name="model_id" ref="grc_recruitment_bridge.model_hr_document_checklist_line"/>
        <field name="name">x_checklist_id</field>
        <field name="field_description">Document Checklist</field>
        <field name="ttype">many2one</field>
        <field name="relation">x_hr.recruitment_document_checklist</field>
        <field name="on_delete">restrict</field>
    </record>

    <record id="field_hr_document_submission_x_checklist_line_id" model="ir.model.fields">
        <field name="model_id" ref="grc_recruitment_bridge.model_hr_document_submission"/>
        <field name="name">x_checklist_line_id</field>
        <field name="field_description">Checklist Line</field>
        <field name="ttype">many2one</field>
        <field name="relation">x_hr.recruitment_document_checklist_line</field>
        <field name="on_delete">restrict</field>
    </record>

    <record id="field_hr_recruitment_declaration_envelope_line_x_envelope_id" model="ir.model.fields">
        <field name="model_id" ref="grc_recruitment_bridge.model_hr_recruitment_declaration_envelope_line"/>
        <field name="name">x_envelope_id</field>
        <field name="field_description">Declaration Envelope</field>
        <field name="ttype">many2one</field>
        <field name="relation">x_hr.recruitment_declaration_envelope</field>
        <field name="on_delete">restrict</field>
    </record>
</odoo>
