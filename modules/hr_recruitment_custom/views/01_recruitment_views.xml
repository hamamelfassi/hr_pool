<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_job_form_inherit_hr_recruitment_custom" model="ir.ui.view">
        <field name="name">hr.job.form.inherit.hr.recruitment.custom</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_hr_job_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Job Description">
                    <group>
                        <field name="x_baseline_functional_area_id"/>
                        <field name="x_baseline_function_ids" widget="many2many_tags"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_hr_applicant_form_inherit_hr_recruitment_custom" model="ir.ui.view">
        <field name="name">hr.applicant.form.inherit.hr.recruitment.custom</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Role and Duties">
                    <field name="x_role_and_duty_line_ids" context="{'default_x_applicant_id': id}">
                        <list editable="bottom">
                            <field name="x_sequence" widget="handle"/>
                            <field name="x_functional_area_id"/>
                            <field name="x_function_id" domain="[('x_functional_area_id', '=', x_functional_area_id)]"/>
                        </list>
                        <form string="Applicant Function Line">
                            <group>
                                <field name="x_functional_area_id"/>
                                <field name="x_function_id" domain="[('x_functional_area_id', '=', x_functional_area_id)]"/>
                                <field name="x_sequence"/>
                            </group>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
