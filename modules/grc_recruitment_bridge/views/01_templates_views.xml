<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Role template views -->
    <record id="view_hr_role_template_list" model="ir.ui.view">
        <field name="name">x_grc.hr_role_template.list</field>
        <field name="model">x_grc.hr_role_template</field>
        <field name="arch" type="xml">
            <tree string="Role / Job Description Templates">
                <field name="x_code"/>
                <field name="x_name"/>
                <field name="x_source_form_code"/>
                <field name="x_version"/>
                <field name="x_state"/>
            </tree>
        </field>
    </record>
    <record id="view_hr_role_template_search" model="ir.ui.view">
        <field name="name">x_grc.hr_role_template.search</field>
        <field name="model">x_grc.hr_role_template</field>
        <field name="arch" type="xml">
            <search>
                <field name="x_name"/>
                <field name="x_code"/>
                <field name="x_source_form_code"/>
                <filter name="draft" string="Draft" domain="[('x_state','=','draft')]"/>
                <filter name="review" string="Under Review" domain="[('x_state','=','under_review')]"/>
                <filter name="active" string="Active" domain="[('x_state','=','active')]"/>
                <filter name="archived" string="Archived" domain="[('x_state','=','archived')]"/>
            </search>
        </field>
    </record>
    <record id="view_hr_role_template_form" model="ir.ui.view">
        <field name="name">x_grc.hr_role_template.form</field>
        <field name="model">x_grc.hr_role_template</field>
        <field name="arch" type="xml">
            <form string="Role / Job Description Template">
                <sheet>
                    <group>
                        <group>
                            <field name="x_code"/>
                            <field name="x_name"/>
                            <field name="x_source_form_code"/>
                            <field name="x_source_form_title"/>
                        </group>
                        <group>
                            <field name="x_state"/>
                            <field name="x_version"/>
                            <field name="x_effective_date"/>
                            <field name="x_retired_date"/>
                            <field name="x_is_default"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Overview">
                            <field name="x_description"/>
                            <field name="x_notes"/>
                        </page>
                        <page string="Composition Lines">
                            <field name="x_line_ids">
                                <list>
                                    <field name="x_sequence"/>
                                    <field name="x_functional_area_id"/>
                                    <field name="x_function_id" domain="[('x_functional_area_id', '=', x_functional_area_id)]"/>
                                    <field name="x_minimum_requirement"/>
                                    <field name="x_expected_output"/>
                                    <field name="x_required"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

