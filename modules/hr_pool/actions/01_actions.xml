<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_hr_pool" model="ir.actions.act_window">
        <field name="name">HR Pool Records / By Chairman Decision</field>
        <field name="res_model">x_hr.pool</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="mobile_view_mode">kanban</field>
        <field name="limit">80</field>
        <field name="context">{'default_x_active': True, 'default_x_intake_phase': 'prescreening', 'default_x_chairman_decision': 'pending', 'group_by': 'x_chairman_decision'}</field>
    </record>

    <record id="action_hr_pool_view_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="hr_pool.view_hr_pool_kanban"/>
        <field name="act_window_id" ref="hr_pool.action_hr_pool"/>
    </record>
    <record id="action_hr_pool_view_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="hr_pool.view_hr_pool_list"/>
        <field name="act_window_id" ref="hr_pool.action_hr_pool"/>
    </record>
    <record id="action_hr_pool_view_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="hr_pool.view_hr_pool_form"/>
        <field name="act_window_id" ref="hr_pool.action_hr_pool"/>
    </record>

    <record id="action_hr_pool_by_phase" model="ir.actions.act_window">
        <field name="name">HR Pool Records / By Intake Phase</field>
        <field name="res_model">x_hr.pool</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="mobile_view_mode">kanban</field>
        <field name="limit">80</field>
        <field name="context">{'default_x_active': True, 'default_x_intake_phase': 'prescreening', 'default_x_chairman_decision': 'pending', 'group_by': 'x_intake_phase'}</field>
    </record>

    <record id="action_hr_pool_by_phase_view_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="hr_pool.view_hr_pool_kanban_by_phase"/>
        <field name="act_window_id" ref="hr_pool.action_hr_pool_by_phase"/>
    </record>
    <record id="action_hr_pool_by_phase_view_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="hr_pool.view_hr_pool_list"/>
        <field name="act_window_id" ref="hr_pool.action_hr_pool_by_phase"/>
    </record>
    <record id="action_hr_pool_by_phase_view_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="hr_pool.view_hr_pool_form"/>
        <field name="act_window_id" ref="hr_pool.action_hr_pool_by_phase"/>
    </record>

    <record id="action_commitment_type" model="ir.actions.act_window">
        <field name="name">Commitment Types</field>
        <field name="res_model">x_hr.commitment_type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_hr_pool_all" model="ir.actions.act_window">
        <field name="name">HR Pool Records / All Records</field>
        <field name="res_model">x_hr.pool</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="mobile_view_mode">list</field>
        <field name="limit">80</field>
        <field name="context">{'default_x_active': True, 'default_x_intake_phase': 'prescreening', 'default_x_chairman_decision': 'pending'}</field>
    </record>

    <record id="action_hr_pool_all_view_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="hr_pool.view_hr_pool_list"/>
        <field name="act_window_id" ref="hr_pool.action_hr_pool_all"/>
    </record>
    <record id="action_hr_pool_all_view_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="hr_pool.view_hr_pool_kanban"/>
        <field name="act_window_id" ref="hr_pool.action_hr_pool_all"/>
    </record>
    <record id="action_hr_pool_all_view_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="hr_pool.view_hr_pool_form"/>
        <field name="act_window_id" ref="hr_pool.action_hr_pool_all"/>
    </record>

    <record id="action_preferred_role_type" model="ir.actions.act_window">
        <field name="name">Preferred Role Types</field>
        <field name="res_model">x_hr.preferred_role_type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_hr_language" model="ir.actions.act_window">
        <field name="name">Languages</field>
        <field name="res_model">x_hr.language</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_skill_type" model="ir.actions.act_window">
        <field name="name">Skill Types</field>
        <field name="res_model">x_hr.skill_type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_proficiency_level" model="ir.actions.act_window">
        <field name="name">Proficiency Levels</field>
        <field name="res_model">x_hr.proficiency_level</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
