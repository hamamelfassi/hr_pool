<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_hr_declaration_envelope_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <style>
                            .marsellia-table { width: 100%; border-collapse: collapse; font-size: 11px; }
                            .marsellia-table th, .marsellia-table td { border: 1px solid #222; padding: 4px 6px; vertical-align: top; }
                            .marsellia-title { margin-bottom: 8px; font-weight: 700; font-size: 16px; }
                            .marsellia-section { margin-top: 14px; }
                            .marsellia-subtitle { font-weight: 700; margin: 8px 0 4px 0; }
                        </style>
                        <div class="marsellia-title">Declaration Envelope</div>
                        <table class="marsellia-table">
                            <tr>
                                <th>Code</th>
                                <td><span t-field="o.x_code"/></td>
                                <th>State</th>
                                <td><span t-field="o.x_state"/></td>
                            </tr>
                            <tr>
                                <th>Applicant</th>
                                <td><span t-field="o.x_applicant_id"/></td>
                                <th>Job</th>
                                <td><span t-field="o.x_job_id"/></td>
                            </tr>
                            <tr>
                                <th>Declaration Pack</th>
                                <td><span t-field="o.x_declaration_pack_id"/></td>
                                <th>Signature Profile</th>
                                <td><span t-field="o.x_signature_profile_id"/></td>
                            </tr>
                            <tr>
                                <th>Documents Folder</th>
                                <td><span t-field="o.x_documents_folder_id"/></td>
                                <th>Signed Attachment</th>
                                <td><span t-field="o.x_signed_pdf_attachment_id"/></td>
                            </tr>
                        </table>

                        <div class="marsellia-section">
                            <div class="marsellia-subtitle">Declaration Lines</div>
                            <table class="marsellia-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Declaration</th>
                                        <th>Signer Role</th>
                                        <th>Signed</th>
                                        <th>Signed At</th>
                                        <th>Signed By</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.x_line_ids" t-as="line">
                                        <tr>
                                            <td><span t-esc="line.x_sequence"/></td>
                                            <td>
                                                <t t-if="line.x_declaration_pack_line_id">
                                                    <span t-esc="line.x_declaration_pack_line_id.x_description or line.x_declaration_pack_line_id.display_name"/>
                                                </t>
                                            </td>
                                            <td><span t-field="line.x_signer_role"/></td>
                                            <td><span t-field="line.x_is_signed"/></td>
                                            <td><span t-field="line.x_signed_at"/></td>
                                            <td><span t-field="line.x_signed_by_id"/></td>
                                        </tr>
                                        <tr>
                                            <td colspan="6"><strong>Notes:</strong> <span t-field="line.x_notes"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <div class="marsellia-section">
                            <div class="marsellia-subtitle">Envelope Notes</div>
                            <p><span t-field="o.x_notes"/></p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
