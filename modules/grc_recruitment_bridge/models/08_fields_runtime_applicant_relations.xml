<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Applicant runtime relation fields are loaded last -->
    <record id="field_hr_applicant_x_role_composition_ids" model="ir.model.fields">
        <field name="model_id" search="[('model','=','hr.applicant')]"/>
        <field name="name">x_role_composition_ids</field>
        <field name="field_description">Role Compositions</field>
        <field name="ttype">one2many</field>
        <field name="relation">x_hr.recruitment_role_composition</field>
        <field name="relation_field">x_applicant_id</field>
    </record>
