<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_hr_interview_evaluation" model="ir.actions.report">
        <field name="name">Interview Evaluation</field>
        <field name="model">x_grc.hr_interview_evaluation</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">grc_recruitment_bridge.report_hr_interview_evaluation_document</field>
        <field name="report_file">grc_recruitment_bridge.report_hr_interview_evaluation_document</field>
        <field name="paperformat_id" ref="grc_recruitment_bridge.paperformat_hr_recruitment_native"/>
        <field name="binding_model_id" ref="grc_recruitment_bridge.model_hr_interview_evaluation"/>
        <field name="binding_view_types">form</field>
        <field name="attachment_use" eval="True"/>
        <field name="attachment">'%s - Interview Evaluation.pdf' % (object.x_code or object.display_name or 'Interview Evaluation')</field>
    </record>
</odoo>
